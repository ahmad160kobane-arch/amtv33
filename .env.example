# ─── Server ───────────────────────────────────────────────
PORT=8090
NODE_ENV=production

# ─── Backend API (Railway) ────────────────────────────────
# Cloud server fetches user auth from the backend API
BACKEND_URL=https://amtv33-production.up.railway.app

# ─── Database ─────────────────────────────────────────────
# Local independent DB (auto-created)
DB_PATH=./data/cloud.db

# ─── JWT (must match backend-api) ─────────────────────────
JWT_SECRET=change-me-to-match-backend-api-secret

# ─── FFmpeg ───────────────────────────────────────────────
# On VPS with system FFmpeg installed, use:
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# ─── TMDB ─────────────────────────────────────────────────
TMDB_API_KEY=
TMDB_BEARER_TOKEN=

# ─── Xtream IPTV ──────────────────────────────────────────
# Credentials are in lib/xtream.js — update there if changed
