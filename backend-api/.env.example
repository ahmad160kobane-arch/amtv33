# ─── Required ─────────────────────────────────────────────
# JWT secret — change to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# ─── Cloud Server ─────────────────────────────────────────
# URL of the cloud streaming server (Railway or VPS)
CLOUD_SERVER_URL=http://localhost:8090

# Internal secret shared between backend-api and cloud-server
INTERNAL_SECRET=cloud-internal-secret-change-me

# ─── Database ─────────────────────────────────────────────
# Path to SQLite DB file.
# On Railway with a Volume mounted at /data → set to /data/ma_streaming.db
DB_PATH=./data/ma_streaming.db

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all)
# Example: https://myapp.vercel.app,https://myapp.netlify.app
CORS_ORIGIN=

# ─── Server ───────────────────────────────────────────────
# Railway sets PORT automatically — do not override in production
PORT=3000
NODE_ENV=production
